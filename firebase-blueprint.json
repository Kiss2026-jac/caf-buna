{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A coffee product sold in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "imageUrl": { "type": "string" },
        "mercadoLivreUrl": { "type": "string" },
        "isFeatured": { "type": "boolean" }
      },
      "required": ["name", "price", "imageUrl"]
    },
    "History": {
      "title": "History",
      "description": "Text and video content for history pages",
      "type": "object",
      "properties": {
        "nossaHistoria": { "type": "string" },
        "historiaCafe": { "type": "string" },
        "guiaPreparo": { "type": "string" },
        "videoNossaHistoria": { "type": "string" },
        "videoHistoriaCafe": { "type": "string" },
        "videoGuiaPreparo": { "type": "string" }
      }
    },
    "Layout": {
      "title": "Layout",
      "description": "Layout configuration and banners",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string" },
        "primaryColor": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "copyrightYear": { "type": "string" },
        "developerName": { "type": "string" },
        "developerUrl": { "type": "string" },
        "banners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "subtitle": { "type": "string" },
              "image": { "type": "string" }
            }
          }
        }
      }
    },
    "SocialMedia": {
      "title": "Social Media",
      "description": "Social media links for the footer",
      "type": "object",
      "properties": {
        "instagram": { "type": "string" },
        "facebook": { "type": "string" },
        "whatsapp": { "type": "string" },
        "youtube": { "type": "string" },
        "tiktok": { "type": "string" }
      }
    },
    "AssinaturaContent": {
      "title": "Assinatura Content",
      "description": "Content and plans for the subscription page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "plans": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "string" },
              "description": { "type": "string" },
              "features": {
                "type": "array",
                "items": { "type": "string" }
              },
              "isPopular": { "type": "boolean" },
              "checkoutUrl": { "type": "string" }
            }
          }
        }
      }
    },
    "FAQ": {
      "title": "FAQ",
      "description": "Frequently Asked Questions",
      "type": "object",
      "properties": {
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          }
        }
      }
    },
    "LegalPages": {
      "title": "Legal Pages",
      "description": "Content for legal and support pages",
      "type": "object",
      "properties": {
        "envios": { "type": "string" },
        "trocas": { "type": "string" },
        "contato": { "type": "string" }
      }
    },
    "Ads": {
      "title": "Ads",
      "description": "Global advertising banners",
      "type": "object",
      "properties": {
        "ads": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "imageUrl": { "type": "string" },
              "linkUrl": { "type": "string" },
              "isActive": { "type": "boolean" }
            }
          }
        }
      }
    },
    "User": {
      "title": "User",
      "description": "Admin user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products"
    },
    "/settings/history": {
      "schema": { "$ref": "#/entities/History" },
      "description": "History and video settings"
    },
    "/settings/layout": {
      "schema": { "$ref": "#/entities/Layout" },
      "description": "Layout and banner settings"
    },
    "/settings/social_media": {
      "schema": { "$ref": "#/entities/SocialMedia" },
      "description": "Social media links"
    },
    "/settings/assinatura_content": {
      "schema": { "$ref": "#/entities/AssinaturaContent" },
      "description": "Subscription plans and content"
    },
    "/settings/faq": {
      "schema": { "$ref": "#/entities/FAQ" },
      "description": "Frequently Asked Questions"
    },
    "/settings/legal_pages": {
      "schema": { "$ref": "#/entities/LegalPages" },
      "description": "Content for legal pages like envios, trocas, contato"
    },
    "/settings/ads": {
      "schema": { "$ref": "#/entities/Ads" },
      "description": "Global advertising banners"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Admin users"
    }
  }
}
